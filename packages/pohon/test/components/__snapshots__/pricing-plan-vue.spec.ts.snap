// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`PricingPlan > renders with as correctly 1`] = `
"<section data-orientation="vertical" data-slot="root">
  <!--v-if-->
  <div data-slot="body" class="">
    <div data-slot="titleWrapper" class="">
      <div data-slot="title" class="">Title</div><span data-slot="badge" class=""><!--v-if--><span data-slot="label" class="">Badge</span>
      <!--v-if--></span>
    </div>
    <div data-slot="description" class="">Description</div>
    <div data-slot="priceWrapper" class="">
      <div data-slot="discount" class="">$249</div>
      <div data-slot="price" class="">$199</div>
      <div data-slot="billing" class=""><span data-slot="billingPeriod" class="">billed annually</span><span data-slot="billingCycle" class="">/month</span></div>
    </div>
    <ul data-slot="features" class="">
      <li data-slot="feature" class=""><svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" aria-hidden="true" role="img" width="1em" height="1em" viewBox="0 0 16 16" data-slot="featureIcon" class=""></svg><span data-slot="featureTitle" class="">Feature 1</span></li>
      <li data-slot="feature" class=""><svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" aria-hidden="true" role="img" width="1em" height="1em" viewBox="0 0 16 16" data-slot="featureIcon" class=""></svg><span data-slot="featureTitle" class="">Feature 2</span></li>
      <li data-slot="feature" class=""><svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" aria-hidden="true" role="img" width="1em" height="1em" viewBox="0 0 16 16" data-slot="featureIcon" class=""></svg><span data-slot="featureTitle" class="">Feature 3</span></li>
    </ul>
  </div>
  <div data-slot="footer" class="">
    <div data-slot="tagline" class="">Tagline</div>
    <!--v-if--><button type="button" data-slot="base" class="">
      <!--v-if--><span data-slot="label" class="">Buy now</span>
      <!--v-if-->
    </button>
    <div data-slot="terms" class="">Terms</div>
  </div>
</section>"
`;

