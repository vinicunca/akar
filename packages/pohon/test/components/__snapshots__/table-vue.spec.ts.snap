exports[`Table > renders with as correctly 1`] = `
"<section data-slot="root">
  <table data-slot="base" class="">
    <!--v-if-->
    <thead data-slot="thead" class="">
      <tr data-slot="tr" class="">
        <th data-pinned="false" scope="col" data-slot="th" class="">Id</th>
        <th data-pinned="false" scope="col" data-slot="th" class="">Amount</th>
        <th data-pinned="false" scope="col" data-slot="th" class="">Status</th>
        <th data-pinned="false" scope="col" data-slot="th" class="">Email</th>
      </tr>
      <tr data-slot="separator" class=""></tr>
    </thead>
    <tbody data-slot="tbody" class="">
      <tr data-selected="false" data-selectable="false" data-expanded="false" data-slot="tr" class="">
        <td data-pinned="false" data-slot="td" class="">m5gr84i9</td>
        <td data-pinned="false" data-slot="td" class="">316</td>
        <td data-pinned="false" data-slot="td" class="">success</td>
        <td data-pinned="false" data-slot="td" class="">ken99@yahoo.com</td>
      </tr>
      <!--v-if-->
      <tr data-selected="false" data-selectable="false" data-expanded="false" data-slot="tr" class="">
        <td data-pinned="false" data-slot="td" class="">3u1reuv4</td>
        <td data-pinned="false" data-slot="td" class="">242</td>
