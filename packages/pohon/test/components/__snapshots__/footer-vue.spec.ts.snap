// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Footer > renders with as correctly 1`] = `
"<section data-slot="root" class="">
  <!--v-if-->
  <div class="" data-slot="container">
    <div data-slot="right" class=""></div>
    <div data-slot="center" class=""></div>
    <div data-slot="left" class=""></div>
  </div>
  <!--v-if-->
</section>"
`;

