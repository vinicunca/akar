// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Form > custom validation works > with error 1`] = `
"<form id="42" class="">
  <div data-slot="root" class="" id="emailField">
    <div data-slot="wrapper" class="">
      <!--v-if-->
      <!--v-if-->
    </div>
    <div class="">
      <div data-slot="root" class="">
        <!--v-if--><input id="email" type="text" name="email" data-slot="base" autocomplete="off" aria-invalid="false" value="bob@dylan.com">
        <!--v-if-->
      </div>
      <!--v-if-->
    </div>
  </div>
  <div data-slot="root" class="" id="passwordField">
    <div data-slot="wrapper" class="">
      <!--v-if-->
      <!--v-if-->
    </div>
    <div class="">
      <div data-slot="root" class="">
        <!--v-if--><input id="password" type="text" name="password" data-slot="base" autocomplete="off" aria-invalid="true" value="short" aria-describedby="v-0-0-1-error">
        <!--v-if-->
      </div>
      <div id="v-0-0-1-error" data-slot="error" class="">Must be at least 8 characters</div>
    </div>
  </div>
</form>"
`;

