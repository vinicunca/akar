exports[`Sidebar > renders with actions slot correctly 1`] = `
"<!-- Non-collapsible: simple inline sidebar -->
<!-- Collapsible: fixed sidebar with gap spacer + mobile menu -->
<aside data-slot="root" data-state="expanded" data-variant="sidebar" data-side="left">
  <!-- Gap spacer: reserves layout space for the fixed sidebar -->
  <div data-slot="gap" data-state="expanded" class=""></div><!-- Fixed container: the actual visible sidebar -->
  <div data-slot="container" data-state="expanded" class="">
    <div data-slot="inner" class="">
      <div data-slot="header" class="">
        <!--v-if-->
        <div data-slot="actions" class="">Actions slot
          <!--v-if-->
        </div>
      </div>
      <div data-slot="body" class=""></div>
      <!--v-if-->
    </div>
    <!--v-if-->
  </div>
</aside>
<!-- Mobile menu -->
<!--v-if-->"
`;

