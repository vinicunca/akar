// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`ChatReasoning > renders with chevron leading correctly 1`] = `
"<div data-state="closed" data-slot="root" class=""><button type="button" data-slot="trigger" class="" aria-controls="" aria-expanded="false" data-state="closed"><span data-slot="leading" class=""><!--v-if--><svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" aria-hidden="true" role="img" width="1em" height="1em" viewBox="0 0 16 16" data-slot="chevronIcon" class=""></svg></span><span data-slot="label" class="">Thought</span>
    <!--v-if-->
  </button>
  <div data-slot="content" class="" id="akar-collapsible-content-v-0" hidden="" data-state="closed" style="--akar-collapsible-content-height: 0px; --akar-collapsible-content-width: 0px;">
    <div data-slot="body" class="">The user is asking about Vue components...</div>
  </div>
</div>"
`;

