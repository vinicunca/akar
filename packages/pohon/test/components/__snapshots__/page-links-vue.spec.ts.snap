exports[`PageLinks > renders with as correctly 1`] = `
"<div data-slot="root" class="">
  <!--v-if-->
  <ul data-slot="list" class="">
    <li data-slot="item" class=""><a href="/docs" data-slot="link"><svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" aria-hidden="true" role="img" width="1em" height="1em" viewBox="0 0 16 16" data-slot="linkLeadingIcon" class=""></svg><span data-slot="linkLabel" class="">Documentation<!--v-if--></span></a></li>
    <li data-slot="item" class=""><a href="https://stackblitz.com/edit/pohon" rel="noopener noreferrer" target="_blank" data-slot="link"><svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" aria-hidden="true" role="img" width="1em" height="1em" viewBox="0 0 16 16" data-slot="linkLeadingIcon" class=""></svg><span data-slot="linkLabel" class="">Playground<svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" aria-hidden="true" role="img" width="1em" height="1em" viewBox="0 0 16 16" data-slot="linkLabelExternalIcon" class=""></svg></span></a></li>
    <li data-slot="item" class=""><button type="button" data-slot="link"><svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" aria-hidden="true" role="img" width="1em" height="1em" viewBox="0 0 16 16" data-slot="linkLeadingIcon" class=""></svg><span data-slot="linkLabel" class="">Roadmap<!--v-if--></span></button></li>
    <li data-slot="item" class=""><a href="https://github.com/vinicunca/pohon/releases" rel="noopener noreferrer" target="_blank" data-slot="link"><svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" aria-hidden="true" role="img" width="1em" height="1em" viewBox="0 0 16 16" data-slot="linkLeadingIcon" class=""></svg><span data-slot="linkLabel" class="">Releases<svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" aria-hidden="true" role="img" width="1em" height="1em" viewBox="0 0 16 16" data-slot="linkLabelExternalIcon" class=""></svg></span></a></li>
  </ul>
</div>"
`;

