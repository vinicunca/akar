exports[`Alert > renders with actions correctly 1`] = `
"<div data-orientation="vertical" data-slot="root" class="">
  <!--v-if-->
  <div data-slot="wrapper" class="">
    <div data-slot="title" class="">Alert</div>
    <!--v-if-->
    <div data-slot="actions" class=""><button type="button" data-slot="base" class="">
        <!--v-if--><span data-slot="label" class="">Action</span>
        <!--v-if-->
      </button></div>
  </div>
  <!--v-if-->
</div>"
`;

