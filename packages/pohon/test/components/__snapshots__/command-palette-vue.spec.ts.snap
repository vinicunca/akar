        </button><button type="button" data-slot="item" id="akar-listbox-item-v-8" role="option" tabindex="-1" aria-selected="false" data-state="unchecked" data-akar-collection-item="">
          <div data-slot="root" class=""><span data-slot="base" class=""></span></div>
          <!--v-if--><span data-slot="itemTrailing" class=""><!--v-if--><!--v-if--></span>
        </button>
      </div>
      <div role="group" aria-labelledby="akar-listbox-group-v-9" data-slot="group" class="">
        <!--v-if--><a href="https://github.com/benjamincanac" role="option" tabindex="-1" rel="noopener noreferrer" target="_blank" data-slot="item" id="akar-listbox-item-v-10" aria-selected="false" data-state="unchecked" data-akar-collection-item=""><span data-slot="root"><img src="https://github.com/benjamincanac.png" alt="Benjamin Canac" data-slot="image"></span>
          <!--v-if--><span data-slot="itemTrailing" class=""><!--v-if--><!--v-if--></span>
        </a>
      </div>
    </div>
  </div>
  <!--v-if-->
  <!--v-if-->
</div>"
`;

