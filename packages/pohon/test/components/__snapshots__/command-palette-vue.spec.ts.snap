        </button><button type="button" disabled="" data-slot="item" id="akar-listbox-item-v-3" role="option" tabindex="-1" aria-selected="false" data-disabled="" data-state="unchecked" data-akar-collection-item=""><svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" aria-hidden="true" role="img" width="1em" height="1em" viewBox="0 0 16 16" data-slot="itemLeadingIcon" class=""></svg><span data-slot="itemWrapper" class=""><span data-slot="itemLabel" class=""><!--v-if--><span data-slot="itemLabelBase" class="">i-lucide-hash</span><span data-slot="itemLabelSuffix" class="">Add a hashtag to the current item.</span></span>
          <!--v-if--></span><span data-slot="itemTrailing" class=""><span data-slot="itemTrailingKbds" class=""><kbd class="">Ctrl</kbd><kbd class="">H</kbd></span>
          <!--v-if--></span>
        </button><button type="button" data-slot="item" id="akar-listbox-item-v-4" role="option" tabindex="-1" aria-selected="false" data-state="unchecked" data-akar-collection-item=""><svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" aria-hidden="true" role="img" width="1em" height="1em" viewBox="0 0 16 16" data-slot="itemLeadingIcon" class=""></svg><span data-slot="itemWrapper" class=""><span data-slot="itemLabel" class=""><!--v-if--><span data-slot="itemLabelBase" class="">i-lucide-tag</span><span data-slot="itemLabelSuffix" class="">Add a label to the current item.</span></span>
