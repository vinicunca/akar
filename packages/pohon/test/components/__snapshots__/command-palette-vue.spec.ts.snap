exports[`CommandPalette > renders with as correctly 1`] = `
"<section dir="ltr" data-slot="root">
  <div data-slot="root" class=""><span data-slot="leading" class=""><svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" aria-hidden="true" role="img" width="1em" height="1em" viewBox="0 0 16 16" data-slot="leadingIcon" class=""></svg></span><input type="text" placeholder="Type a command or search…" data-slot="input" autocomplete="off" aria-disabled="false" value="">
    <!--v-if-->
  </div>
  <div role="listbox" tabindex="-1" aria-orientation="vertical" aria-multiselectable="false" data-orientation="vertical" data-slot="content" class="">
    <div role="presentation" data-slot="viewport" class="">
      <div role="group" aria-labelledby="akar-listbox-group-v-0" data-slot="group" class="">
        <!--v-if--><button type="button" data-slot="item" id="akar-listbox-item-v-1" role="option" tabindex="-1" aria-selected="false" data-state="unchecked" data-akar-collection-item=""><svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" aria-hidden="true" role="img" width="1em" height="1em" viewBox="0 0 16 16" data-slot="itemLeadingIcon" class=""></svg><span data-slot="itemWrapper" class=""><span data-slot="itemLabel" class=""><!--v-if--><span data-slot="itemLabelBase" class="">Add new file</span><span data-slot="itemLabelSuffix" class="">Create a new file in the current directory or workspace.</span></span>
          <!--v-if--></span><span data-slot="itemTrailing" class=""><span data-slot="itemTrailingKbds" class=""><kbd class="">Ctrl</kbd><kbd class="">N</kbd></span>
          <!--v-if--></span>
        </button><button type="button" data-slot="item" id="akar-listbox-item-v-2" role="option" tabindex="-1" aria-selected="false" data-state="unchecked" data-akar-collection-item=""><svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" aria-hidden="true" role="img" width="1em" height="1em" viewBox="0 0 16 16" data-slot="itemLeadingIcon" class=""></svg><span data-slot="itemWrapper" class=""><span data-slot="itemLabel" class=""><!--v-if--><span data-slot="itemLabelBase" class="">Add new folder</span><span data-slot="itemLabelSuffix" class="">Create a new folder in the current directory or workspace.</span></span>
          <!--v-if--></span><span data-slot="itemTrailing" class=""><span data-slot="itemTrailingKbds" class=""><kbd class="">Ctrl</kbd><kbd class="">F</kbd></span>
          <!--v-if--></span>
        </button><button type="button" disabled="" data-slot="item" id="akar-listbox-item-v-3" role="option" tabindex="-1" aria-selected="false" data-disabled="" data-state="unchecked" data-akar-collection-item=""><svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" aria-hidden="true" role="img" width="1em" height="1em" viewBox="0 0 16 16" data-slot="itemLeadingIcon" class=""></svg><span data-slot="itemWrapper" class=""><span data-slot="itemLabel" class=""><!--v-if--><span data-slot="itemLabelBase" class="">Add hashtag</span><span data-slot="itemLabelSuffix" class="">Add a hashtag to the current item.</span></span>
          <!--v-if--></span><span data-slot="itemTrailing" class=""><span data-slot="itemTrailingKbds" class=""><kbd class="">Ctrl</kbd><kbd class="">H</kbd></span>
          <!--v-if--></span>
        </button><button type="button" data-slot="item" id="akar-listbox-item-v-4" role="option" tabindex="-1" aria-selected="false" data-state="unchecked" data-akar-collection-item=""><svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" aria-hidden="true" role="img" width="1em" height="1em" viewBox="0 0 16 16" data-slot="itemLeadingIcon" class=""></svg><span data-slot="itemWrapper" class=""><span data-slot="itemLabel" class=""><!--v-if--><span data-slot="itemLabelBase" class="">Add label</span><span data-slot="itemLabelSuffix" class="">Add a label to the current item.</span></span>
          <!--v-if--></span><span data-slot="itemTrailing" class=""><span data-slot="itemTrailingKbds" class=""><kbd class="">Ctrl</kbd><kbd class="">L</kbd></span>
          <!--v-if--></span>
        </button>
      </div>
      <div role="group" aria-labelledby="akar-listbox-group-v-5" data-slot="group" class="">
        <div id="akar-listbox-group-v-5" data-slot="label" class="">Labels</div><button type="button" data-slot="item" id="akar-listbox-item-v-6" role="option" tabindex="-1" aria-selected="false" data-state="unchecked" data-akar-collection-item="">
          <div data-slot="root" class=""><span data-slot="base" class=""></span></div><span data-slot="itemWrapper" class=""><span data-slot="itemLabel" class=""><!--v-if--><span data-slot="itemLabelBase" class="">bug</span>
          <!--v-if--></span>
          <!--v-if--></span><span data-slot="itemTrailing" class=""><!--v-if--><!--v-if--></span>
        </button><button type="button" data-slot="item" id="akar-listbox-item-v-7" role="option" tabindex="-1" aria-selected="false" data-state="unchecked" data-akar-collection-item="">
          <div data-slot="root" class=""><span data-slot="base" class=""></span></div><span data-slot="itemWrapper" class=""><span data-slot="itemLabel" class=""><!--v-if--><span data-slot="itemLabelBase" class="">feature</span>
          <!--v-if--></span>
          <!--v-if--></span><span data-slot="itemTrailing" class=""><!--v-if--><!--v-if--></span>
        </button><button type="button" data-slot="item" id="akar-listbox-item-v-8" role="option" tabindex="-1" aria-selected="false" data-state="unchecked" data-akar-collection-item="">
          <div data-slot="root" class=""><span data-slot="base" class=""></span></div><span data-slot="itemWrapper" class=""><span data-slot="itemLabel" class=""><!--v-if--><span data-slot="itemLabelBase" class="">enhancement</span>
          <!--v-if--></span>
          <!--v-if--></span><span data-slot="itemTrailing" class=""><!--v-if--><!--v-if--></span>
        </button>
      </div>
      <div role="group" aria-labelledby="akar-listbox-group-v-9" data-slot="group" class="">
        <div id="akar-listbox-group-v-9" data-slot="label" class="">Users</div><a href="https://github.com/benjamincanac" role="option" tabindex="-1" rel="noopener noreferrer" target="_blank" data-slot="item" id="akar-listbox-item-v-10" aria-selected="false" data-state="unchecked" data-akar-collection-item=""><span data-slot="root"><img src="https://github.com/benjamincanac.png" alt="Benjamin Canac" data-slot="image"></span><span data-slot="itemWrapper" class=""><span data-slot="itemLabel" class=""><!--v-if--><span data-slot="itemLabelBase" class="">benjamincanac</span>
          <!--v-if--></span>
          <!--v-if--></span><span data-slot="itemTrailing" class=""><!--v-if--><!--v-if--></span>
        </a>
      </div>
    </div>
  </div>
  <!--v-if-->
  <!--v-if-->
</section>"
`;

