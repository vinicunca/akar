// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Editor > renders with as correctly 1`] = `
"<section data-slot="root" class="">
  <div role="presentation" data-slot="content" class="">
    <div contenteditable="true" autocomplete="off" autocorrect="off" autocapitalize="off" translate="no" class="tiptap ProseMirror undefined" tabindex="0">
      <p><br class="ProseMirror-trailingBreak"></p>
    </div>
  </div>
</section>"
`;

