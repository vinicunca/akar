    <li data-slot="item" class=""><button type="button" data-slot="link"><span class="iconify i-lucide:map" aria-hidden="true" data-slot="linkLeadingIcon"></span><span data-slot="linkLabel" class="">Roadmap<!--v-if--></span></button></li>
    <li data-slot="item" class=""><a href="https://github.com/vinicunca/pohon/releases" rel="noopener noreferrer" target="_blank" data-slot="link"><span class="iconify i-lucide:rocket" aria-hidden="true" data-slot="linkLeadingIcon"></span><span data-slot="linkLabel" class="">Releases<span class="iconify i-lucide:arrow-up-right" aria-hidden="true" data-slot="linkLabelExternalIcon"></span></span></a></li>
  </ul>
</div>"
`;

