// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`PageLinks > renders with as correctly 1`] = `
"<div data-slot="root" class="">
  <!--v-if-->
  <ul data-slot="list" class="">
    <li data-slot="item" class=""><a href="/docs" data-slot="link"><span class="iconify i-lucide:book-open" aria-hidden="true" data-slot="linkLeadingIcon"></span><span data-slot="linkLabel" class="">Documentation<!--v-if--></span></a></li>
