    <div role="region" aria-labelledby="akar-accordion-trigger-v-0-0-10" data-state="closed" data-orientation="vertical" style="--akar-accordion-content-width: var(--akar-collapsible-content-width); --akar-accordion-content-height: var(--akar-collapsible-content-height); --akar-collapsible-content-height: 0px; --akar-collapsible-content-width: 0px;" data-slot="content" class="" id="akar-collapsible-content-v-0-0-11" hidden="">
