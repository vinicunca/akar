// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`ChatMessages > renders with assistant correctly 1`] = `
"<div data-slot="root" class="" style="--last-message-height: 0px;">
  <article data-role="user" data-slot="root" class="">
    <!--v-if-->
    <div data-slot="container" class="">
      <!--v-if-->
      <div data-slot="content" class="">Hello, how are you?</div>
      <!--v-if-->
    </div>
  </article>
  <article data-role="assistant" data-slot="root" class="">
    <!--v-if-->
    <div data-slot="container" class="">
      <div data-slot="leading" class=""><span data-slot="root"><svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" aria-hidden="true" role="img" width="1em" height="1em" viewBox="0 0 16 16" data-slot="icon" class=""></svg></span></div>
      <div data-slot="content" class="">I am fine, thank you!</div>
      <!--v-if-->
    </div>
  </article>
  <!--v-if-->
  <!---->
</div>"
`;

