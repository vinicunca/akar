// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`AuthForm > renders with as correctly 1`] = `
"<section data-slot="root" class="">
  <!--v-if-->
  <div data-slot="body" class="">
    <!--v-if-->
    <!--v-if-->
    <form id="v-0" class="" data-slot="form">
      <div data-slot="root" class="">
        <div data-slot="wrapper" class="">
          <div data-slot="labelWrapper" class=""><label for="v-1" data-slot="label" class="">Email</label>
            <!--v-if-->
          </div>
          <!--v-if-->
        </div>
        <div class="">
          <div data-slot="root" class="">
            <!--v-if--><input id="v-1" type="text" name="email" data-slot="input" autocomplete="off" aria-invalid="true" aria-describedby="v-1-error">
            <!--v-if-->
          </div>
          <div id="v-1-error" data-slot="error" class="">Invalid email format</div>
        </div>
      </div>
      <div data-slot="root" class="">
        <div data-slot="wrapper" class="">
          <div data-slot="labelWrapper" class=""><label for="v-2" data-slot="label" class="">Password</label>
            <!--v-if-->
          </div>
          <!--v-if-->
        </div>
        <div class="">
          <div data-slot="root" class="">
            <!--v-if--><input id="v-2" type="password" name="password" data-slot="password" autocomplete="off" aria-invalid="false"><span data-slot="trailing" class=""><button type="button" aria-label="Show password" aria-pressed="false" data-slot="base" class="" aria-controls="v-2"><svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" aria-hidden="true" role="img" width="1em" height="1em" viewBox="0 0 16 16" data-slot="leadingIcon" class=""></svg><!--v-if--><!--v-if--></button></span>
          </div>
          <!--v-if-->
        </div>
      </div>
      <!--v-if--><button type="submit" data-slot="base" class="">
        <!--v-if--><span data-slot="label" class="">Continue</span>
        <!--v-if-->
      </button>
    </form>
  </div>
  <!--v-if-->
</section>"
`;

