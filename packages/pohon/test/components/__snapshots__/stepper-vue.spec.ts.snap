exports[`Stepper > renders with as correctly 1`] = `
"<section role="group" aria-label="progress" data-linear="" data-orientation="horizontal" data-slot="root">
  <div data-slot="header" class="">
    <div aria-current="true" data-state="active" data-orientation="horizontal" data-slot="item" class="">
      <div data-slot="container" class=""><button type="button" data-state="active" data-orientation="horizontal" tabindex="0" aria-describedby="akar-stepper-item-description-v-1" aria-labelledby="akar-stepper-item-title-v-0" data-slot="trigger" class="">
          <div data-slot="indicator" class=""><svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" aria-hidden="true" role="img" width="1em" height="1em" viewBox="0 0 16 16" data-slot="icon" class=""></svg></div>
        </button>
        <div data-orientation="horizontal" role="none" data-state="active" data-slot="separator" class=""></div>
      </div>
      <div data-slot="wrapper" class="">
        <div id="akar-stepper-item-title-v-0" data-slot="title" class="">Address</div>
        <div id="akar-stepper-item-description-v-1" data-slot="description" class="">Add your address here</div>
      </div>
    </div>
    <div data-state="inactive" data-orientation="horizontal" data-slot="item" class="">
      <div data-slot="container" class=""><button type="button" data-state="inactive" data-orientation="horizontal" tabindex="0" aria-describedby="akar-stepper-item-description-v-3" aria-labelledby="akar-stepper-item-title-v-2" data-slot="trigger" class="">
          <div data-slot="indicator" class=""><svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" aria-hidden="true" role="img" width="1em" height="1em" viewBox="0 0 16 16" data-slot="icon" class=""></svg></div>
        </button>
        <div data-orientation="horizontal" role="none" data-state="inactive" data-slot="separator" class=""></div>
      </div>
      <div data-slot="wrapper" class="">
        <div id="akar-stepper-item-title-v-2" data-slot="title" class="">Shipping</div>
        <div id="akar-stepper-item-description-v-3" data-slot="description" class="">Set your preferred shipping method</div>
      </div>
    </div>
    <div data-state="inactive" disabled="" data-disabled="" data-orientation="horizontal" data-slot="item" class="">
      <div data-slot="container" class=""><button type="button" data-state="inactive" disabled="" data-disabled="" data-orientation="horizontal" tabindex="-1" aria-describedby="akar-stepper-item-description-v-5" aria-labelledby="akar-stepper-item-title-v-4" data-slot="trigger" class="">
          <div data-slot="indicator" class="">3</div>
        </button>
        <!--v-if-->
      </div>
      <div data-slot="wrapper" class="">
        <div id="akar-stepper-item-title-v-4" data-slot="title" class="">Checkout</div>
        <div id="akar-stepper-item-description-v-5" data-slot="description" class="">Confirm your order</div>
      </div>
    </div>
  </div>
  <!--v-if-->
  <div aria-live="polite" aria-atomic="true" role="status" style="transform: translateX(-100%); position: absolute; pointer-events: none; opacity: 0; margin: 0px;"> Step 0 of 3</div>
</section>"
`;

