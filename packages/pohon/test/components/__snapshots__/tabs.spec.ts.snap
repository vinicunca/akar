// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Tabs > renders with leading slot correctly 1`] = `
"<div dir="ltr" data-orientation="horizontal" data-slot="root">
  <div role="tablist" aria-orientation="horizontal" tabindex="0" data-orientation="horizontal" dir="ltr" style="outline-color: none; outline-style: none; outline-width: initial;" data-slot="list" class="">
    <!--v-if--><button id="akar-tabs-v-0-0-0-trigger-0" role="tab" type="button" aria-selected="true" data-state="active" data-orientation="horizontal" tabindex="-1" data-active="" data-slot="trigger" class="" data-akar-collection-item="" aria-controls="akar-tabs-v-0-0-0-content-0">Leading slot<span data-slot="label" class="">Tab1</span>
      <!--v-if-->
    </button><button id="akar-tabs-v-0-0-0-trigger-1" role="tab" type="button" aria-selected="false" data-state="inactive" data-orientation="horizontal" tabindex="-1" data-slot="trigger" class="" data-akar-collection-item="" aria-controls="akar-tabs-v-0-0-0-content-1">Leading slot<span data-slot="label" class="">Tab2</span>
      <!--v-if-->
    </button><button id="akar-tabs-v-0-0-0-trigger-2" role="tab" type="button" aria-selected="false" data-state="inactive" data-orientation="horizontal" tabindex="-1" data-slot="trigger" class="" data-akar-collection-item="" aria-controls="akar-tabs-v-0-0-0-content-2">Leading slot<span data-slot="label" class="">Tab3</span><span data-slot="trailingBadge" class=""><!--v-if--><span data-slot="label" class="">badge</span>
      <!--v-if--></span>
    </button>
  </div>
  <div id="akar-tabs-v-0-0-0-content-0" role="tabpanel" data-state="active" data-orientation="horizontal" aria-labelledby="akar-tabs-v-0-0-0-trigger-0" tabindex="0" style="animation-duration: 0s;" data-slot="content" class="">This is the content shown for Tab1</div>
  <div id="akar-tabs-v-0-0-0-content-1" role="tabpanel" data-state="inactive" data-orientation="horizontal" aria-labelledby="akar-tabs-v-0-0-0-trigger-1" hidden="" tabindex="0" data-slot="content" class="">
    <!--v-if-->
  </div>
  <div id="akar-tabs-v-0-0-0-content-2" role="tabpanel" data-state="inactive" data-orientation="horizontal" aria-labelledby="akar-tabs-v-0-0-0-trigger-2" hidden="" tabindex="0" data-slot="content" class="">
    <!--v-if-->
  </div>
</div>"
`;
