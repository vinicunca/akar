        <div role="separator" aria-orientation="horizontal" data-slot="separator" class=""></div><button type="button" data-slot="item" role="menuitem" tabindex="-1" data-akar-collection-item="">Item slot</button><button type="button" disabled="" data-slot="item" role="menuitem" tabindex="-1" data-akar-collection-item="" aria-disabled="true" data-disabled="">Item slot</button>
      </div>
      <div role="group" aria-labelledby="akar-menu-group-v-0-0-6" data-slot="group" class=""><button type="button" data-slot="item" role="menuitem" tabindex="-1" data-akar-collection-item="">Item slot</button></div>
    </div>
    <!--v-if-->
  </div>
</div>




<!--teleport end-->"
`;

exports[`DropdownMenu > renders with item-leading slot correctly 1`] = `
"<!--v-if-->
<!--teleport start-->




<div data-akar-popper-content-wrapper="" style="position: fixed; left: 0px; top: 0px; transform: translate(0, -200%); min-width: max-content;">
