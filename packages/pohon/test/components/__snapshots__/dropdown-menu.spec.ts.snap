exports[`DropdownMenu > renders with filter and searchTerm correctly 1`] = `
"<!--v-if-->
<!--teleport start-->




<div data-akar-popper-content-wrapper="" style="position: fixed; left: 0px; top: 0px; transform: translate(0, -200%); min-width: max-content;">
  <div role="menu" aria-orientation="vertical" data-akar-menu-content="" data-state="open" dir="ltr" tabindex="-1" data-orientation="vertical" style="pointer-events: auto; --akar-dropdown-menu-content-transform-origin: var(--akar-popper-transform-origin); --akar-dropdown-menu-content-available-width: var(--akar-popper-available-width); --akar-dropdown-menu-content-available-height: var(--akar-popper-available-height); --akar-dropdown-menu-trigger-width: var(--akar-popper-anchor-width); --akar-dropdown-menu-trigger-height: var(--akar-popper-anchor-height); animation: none; outline-color: none; outline-style: none; outline-width: initial;" data-dismissable-layer="" id="akar-dropdown-menu-content-v-0-0-0" aria-labelledby="" data-slot="content" data-side="bottom" data-align="center">
    <div data-slot="root" class="">
      <!--v-if--><input type="text" placeholder="Search…" data-slot="input" autocomplete="off" role="searchbox" value="No match value">
      <!--v-if-->
    </div>
    <!--v-if-->
