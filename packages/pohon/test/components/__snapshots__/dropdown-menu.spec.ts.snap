          <!--v-if--></span><span data-slot="itemTrailing" class=""><!--v-if--><!----></span>
        </button><button role="menuitem" tabindex="-1" id="akar-menu-sub-trigger-v-0-0-4" aria-haspopup="menu" aria-expanded="false" aria-controls="" data-state="closed" type="button" data-slot="item" class="" data-akar-collection-item="">Item leading slot<span data-slot="itemWrapper" class=""><span data-slot="itemLabel" class="">Invite users<!--v-if--></span>
          <!--v-if--></span><span data-slot="itemTrailing" class=""><span class="iconify i-lucide:chevron-right" aria-hidden="true" data-slot="itemTrailingIcon"></span>
          <!----></span>
        </button>
        <!---->
        <!--teleport start-->
        <!---->
        <!--teleport end--><button type="button" data-slot="item" role="menuitem" tabindex="-1" data-akar-collection-item="">Item leading slot<span data-slot="itemWrapper" class=""><span data-slot="itemLabel" class="">New team<!--v-if--></span>
          <!--v-if--></span><span data-slot="itemTrailing" class=""><span data-slot="itemTrailingKbds" class=""><kbd class="">Ctrl</kbd><kbd class="">n</kbd></span>
          <!----></span>
        </button>
      </div>
      <div role="group" aria-labelledby="akar-menu-group-v-0-0-5" data-slot="group" class=""><a href="https://github.com/vinicunca/pohon" role="menuitem" tabindex="-1" rel="noopener noreferrer" target="_blank" data-slot="item" data-akar-collection-item="">Item leading slot<span data-slot="itemWrapper" class=""><span data-slot="itemLabel" class="">GitHub<span class="iconify i-lucide:arrow-up-right" aria-hidden="true" data-slot="itemLabelExternalIcon"></span></span>
