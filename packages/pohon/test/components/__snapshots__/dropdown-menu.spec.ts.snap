          <!--v-if--></span><span data-slot="itemTrailing" class=""><!--v-if--><!----></span>
        </button><button type="button" data-slot="item" role="menuitem" tabindex="-1" data-akar-collection-item="">Item leading slot<span data-slot="itemWrapper" class=""><span data-slot="itemLabel" class="">Billing<!--v-if--></span>
          <!--v-if--></span><span data-slot="itemTrailing" class=""><span data-slot="itemTrailingKbds" class=""><kbd class="">Ctrl</kbd><kbd class="">b</kbd></span>
          <!----></span>
        </button><button type="button" data-slot="item" role="menuitem" tabindex="-1" data-akar-collection-item="">Item leading slot<span data-slot="itemWrapper" class=""><span data-slot="itemLabel" class="">Settings<!--v-if--></span>
          <!--v-if--></span><span data-slot="itemTrailing" class=""><span data-slot="itemTrailingKbds" class=""><kbd class="">?</kbd></span>
