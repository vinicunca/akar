        <div role="separator" aria-orientation="horizontal" data-slot="separator" class=""></div><button type="button" data-slot="item" role="menuitem" tabindex="-1" data-akar-collection-item="">Item leading slot<span data-slot="itemWrapper" class=""><span data-slot="itemLabel" class="">Keyboard Shortcuts<!--v-if--></span>
          <!--v-if--></span><span data-slot="itemTrailing" class=""><!--v-if--><!----></span>
        </button><button type="button" disabled="" data-slot="item" role="menuitem" tabindex="-1" data-akar-collection-item="" aria-disabled="true" data-disabled="">Item leading slot<span data-slot="itemWrapper" class=""><span data-slot="itemLabel" class="">API<!--v-if--></span>
