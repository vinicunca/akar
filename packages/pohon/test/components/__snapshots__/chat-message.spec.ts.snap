// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`ChatMessage > renders with actions slot correctly 1`] = `
"<article data-role="user" data-slot="root" class="">
  <!--v-if-->
  <div data-slot="container" class="">
    <!--v-if-->
    <div data-slot="content" class="">Hello, how are you?</div>
    <div data-slot="actions" class="">Actions slot</div>
  </div>
</article>"
`;

