// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`FieldGroup > renders orientation vertical with default slot correctly 1`] = `
"<div data-orientation="vertical" class="">
  <div data-slot="root" class="">
    <!--v-if--><input type="text" data-slot="base" autocomplete="off">
    <!--v-if-->
  </div> <button type="button" data-slot="base" class="">
    <!--v-if--> Click me!
    <!--v-if-->
  </button>
</div>"
`;

exports[`FieldGroup > renders with as correctly 1`] = `"<section data-orientation="horizontal" class=""></section>"`;

exports[`FieldGroup > renders with class correctly 1`] = `"<div data-orientation="horizontal" class="absolute"></div>"`;

exports[`FieldGroup > renders with default slot correctly 1`] = `
"<div data-orientation="horizontal" class="">
  <div data-slot="root" class="">
