// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Select > renders with items correctly 1`] = `
"<button role="combobox" type="button" aria-controls="akar-select-content-v-0" aria-expanded="true" aria-required="false" aria-autocomplete="none" dir="ltr" data-state="open" data-placeholder="" data-slot="base" class="">
  <!--v-if--><span style="pointer-events: none;" data-placeholder="" data-slot="placeholder" class="">&nbsp;</span><span data-slot="trailing" class=""><svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" aria-hidden="true" role="img" width="1em" height="1em" viewBox="0 0 16 16" data-slot="trailingIcon" class=""></svg></span>
</button>
<!--teleport start-->



<div data-akar-popper-content-wrapper="" style="position: fixed; left: 0px; top: 0px; transform: translate(0, -200%); min-width: max-content;">
  <div style="box-sizing: border-box; --akar-select-content-transform-origin: var(--akar-popper-transform-origin); --akar-select-content-available-width: var(--akar-popper-available-width); --akar-select-content-available-height: var(--akar-popper-available-height); --akar-select-trigger-width: var(--akar-popper-anchor-width); --akar-select-trigger-height: var(--akar-popper-anchor-height); display: flex; flex-direction: column; animation: none; pointer-events: auto; outline-color: none; outline-style: none; outline-width: initial;" data-slot="content" position="popper" bodylock="true" disableoutsidepointerevents="true" id="akar-select-content-v-0" role="listbox" data-state="open" dir="ltr" data-dismissable-layer="" tabindex="-1" data-side="bottom" data-align="start">
    <div role="presentation" data-slot="viewport" class="">
      <div role="group" aria-labelledby="akar-select-group-v-1" data-slot="group" class="">
        <div role="option" aria-labelledby="akar-select-item-text-v-2" aria-selected="false" data-state="unchecked" tabindex="-1" data-slot="item" class="" data-akar-collection-item=""><svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" aria-hidden="true" role="img" width="1em" height="1em" viewBox="0 0 16 16" data-slot="itemLeadingIcon" class=""></svg><span data-slot="itemWrapper" class=""><span id="akar-select-item-text-v-2" data-slot="itemLabel" class="" data-item-text="">Backlog</span>
          <!--v-if--></span><span data-slot="itemTrailing" class=""><!--v-if--></span>
        </div>
        <div role="option" aria-labelledby="akar-select-item-text-v-3" aria-selected="false" data-state="unchecked" tabindex="-1" data-slot="item" class="" data-akar-collection-item=""><svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" aria-hidden="true" role="img" width="1em" height="1em" viewBox="0 0 16 16" data-slot="itemLeadingIcon" class=""></svg><span data-slot="itemWrapper" class=""><span id="akar-select-item-text-v-3" data-slot="itemLabel" class="" data-item-text="">Todo</span>
          <!--v-if--></span><span data-slot="itemTrailing" class=""><!--v-if--></span>
        </div>
        <div role="option" aria-labelledby="akar-select-item-text-v-4" aria-selected="false" data-state="unchecked" tabindex="-1" data-slot="item" class="" data-akar-collection-item=""><svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" aria-hidden="true" role="img" width="1em" height="1em" viewBox="0 0 16 16" data-slot="itemLeadingIcon" class=""></svg><span data-slot="itemWrapper" class=""><span id="akar-select-item-text-v-4" data-slot="itemLabel" class="" data-item-text="">In Progress</span>
          <!--v-if--></span><span data-slot="itemTrailing" class=""><!--v-if--></span>
        </div>
        <div role="option" aria-labelledby="akar-select-item-text-v-5" aria-selected="false" data-state="unchecked" tabindex="-1" data-slot="item" class="" data-akar-collection-item=""><svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" aria-hidden="true" role="img" width="1em" height="1em" viewBox="0 0 16 16" data-slot="itemLeadingIcon" class=""></svg><span data-slot="itemWrapper" class=""><span id="akar-select-item-text-v-5" data-slot="itemLabel" class="" data-item-text="">Done</span>
          <!--v-if--></span><span data-slot="itemTrailing" class=""><!--v-if--></span>
        </div>
        <div role="option" aria-labelledby="akar-select-item-text-v-6" aria-selected="false" data-state="unchecked" tabindex="-1" data-slot="item" class="" data-akar-collection-item=""><svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" aria-hidden="true" role="img" width="1em" height="1em" viewBox="0 0 16 16" data-slot="itemLeadingIcon" class=""></svg><span data-slot="itemWrapper" class=""><span id="akar-select-item-text-v-6" data-slot="itemLabel" class="" data-item-text="">Canceled</span>
          <!--v-if--></span><span data-slot="itemTrailing" class=""><!--v-if--></span>
        </div>
      </div>
    </div>
    <!--v-if-->
  </div>
</div>



<!--teleport end-->
<!--v-if-->"
`;
