exports[`Table > renders with columns correctly 1`] = `
"<div data-slot="root">
  <table data-slot="base" class="">
    <!--v-if-->
    <thead data-slot="thead" class="">
      <tr data-slot="tr" class="">
        <th data-pinned="false" scope="col" data-slot="th" class="">
          <div data-slot="root" class="">
            <div data-slot="container" class=""><button data-slot="base" id="v-0-0-0" role="checkbox" type="button" aria-checked="false" aria-required="false" data-state="unchecked">
                <!---->
                <!--v-if-->
              </button></div>
            <div data-slot="wrapper" class=""><label for="v-0-0-0" data-slot="label" class="">Select all</label>
              <!--v-if-->
            </div>
          </div>
        </th>
        <th data-pinned="false" scope="col" data-slot="th" class="">#</th>
        <th data-pinned="false" scope="col" data-slot="th" class="">Date</th>
        <th data-pinned="false" scope="col" data-slot="th" class="">Status</th>
        <th data-pinned="false" scope="col" data-slot="th" class=""><button type="button" data-slot="base" class="-mx-2.5"><span class="iconify i-lucide:arrow-up-down" aria-hidden="true" data-slot="leadingIcon"></span><span data-slot="label" class="">Email</span>
            <!--v-if-->
          </button></th>
        <th data-pinned="false" scope="col" data-slot="th" class="text-right">Amount</th>
        <th data-pinned="false" scope="col" data-slot="th" class="">
          <!---->
        </th>
      </tr>
      <tr data-slot="separator" class=""></tr>
    </thead>
    <tbody data-slot="tbody" class="">
      <tr data-selected="false" data-selectable="false" data-expanded="false" data-slot="tr" class="">
        <td data-pinned="false" data-slot="td" class="">
          <div data-slot="root" class="">
            <div data-slot="container" class=""><button aria-label="Select row" data-slot="base" id="v-0-0-1" role="checkbox" type="button" aria-checked="false" aria-required="false" data-state="unchecked">
                <!---->
                <!--v-if-->
              </button></div>
            <!--v-if-->
          </div>
        </td>
        <td data-pinned="false" data-slot="td" class="">#m5gr84i9</td>
        <td data-pinned="false" data-slot="td" class="">Invalid Date</td>
        <td data-pinned="false" data-slot="td" class=""><span data-slot="base" class="capitalize"><!--v-if-->success<!--v-if--></span></td>
