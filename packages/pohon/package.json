    "@nuxt/test-utils": "^4.0.2",
    "@tanstack/table-core": "^8.21.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.6",
    "ai": "^6.0.168",
