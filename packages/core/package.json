{
  "name": "akar",
  "type": "module",
  "version": "1.21.0",
  "description": "Vue UI components",
  "author": "Vinicunca Contributors (https://github.com/vinicunca)",
  "license": "MIT",
  "homepage": "https://github.com/vinicunca/akar#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vinicunca/akar.git"
  },
  "bugs": {
    "url": "https://github.com/vinicunca/akar/issues"
  },
  "keywords": [
    "ui",
    "vue",
    "accessibility",
    "headless",
    "nuxt",
    "components",
    "unstyled",
    "akar"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./constant": {
      "import": "./dist/constant.js",
      "require": "./dist/constant.cjs"
    },
    "./date": {
      "import": "./dist/date.js",
      "require": "./dist/date.cjs"
    },
    "./namespaced": {
      "import": "./dist/namespaced/index.mjs",
      "require": "./dist/namespaced/index.cjs"
    },
    "./nuxt": {
      "import": "./dist/nuxt/index.mjs",
      "require": "./dist/nuxt/index.cjs"
    },
    "./resolver": {
      "import": "./dist/resolver/index.mjs",
      "require": "./dist/resolver/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "!src/**/*.story.vue",
    "!src/**/*.test.*",
    "!src/**/_*.vue",
    "!src/**/__snapshots__",
    "!src/**/stories",
    "!src/**/story",
    "dist",
    "src"
  ],
  "scripts": {
    "build": "pnpm typecheck && pnpm build-only",
    "build-only": "tsdown && tsx scripts/postbuild.ts",
    "watch": "tsdown --watch",
    "typecheck": "vue-tsc -p tsconfig.check.json --noEmit",
    "test": "vitest",
    "test-update": "vitest -u",
    "pub:release": "pnpm publish --access public --no-git-checks",
    "check-sizes": "node scripts/check-sizes.js",
    "track-sizes": "node scripts/track-sizes.js",
    "analyze-components": "node scripts/analyze-components.js",
    "trend-analysis": "node scripts/trend-analysis.js"
  },
  "peerDependencies": {
    "vue": ">= 3.4.0"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.6.13",
    "@floating-ui/vue": "^1.1.6",
    "@internationalized/date": "3.12.1",
    "@internationalized/number": "3.6.5",
    "@tanstack/vue-virtual": "^3.13.23",
    "@vinicunca/perkakas": "1.14.0",
    "@vueuse/core": "^14.2.1",
    "@vueuse/shared": "^14.1.0",
    "aria-hidden": "^1.2.4",
    "defu": "^6.1.7"
  },
  "devDependencies": {
    "@iconify/vue": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@testing-library/vue": "^8.1.0",
    "@tsconfig/node24": "^24.0.0",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^24.0.13",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-istanbul": "^3.2.4",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "jsdom": "^26.1.0",
    "rolldown": "1.0.0-beta.26",
    "tsdown": "0.12.9",
    "vite": "^8.0.8",
    "vitest": "3.2.4",
    "vitest-axe": "0.1.0",
    "vitest-canvas-mock": "^0.3.3",
    "vue": "^3.5.30",
    "vue-component-type-helpers": "^3.0.3",
    "vue-tsc": "3.1.8"
  }
}
